# VAPTForge Enterprise — Environment Configuration
# Copy to .env and configure before running

# ── Core ──────────────────────────────────────────────────────────────────────
APP_NAME=VAPTForge Enterprise
DEBUG=false

# IMPORTANT: Change this in production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-char-secret-before-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development/testing)
DATABASE_URL=sqlite+aiosqlite:///./vapt_platform.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://vapt:password@localhost:5432/vapt_db

# ── CORS — comma-separated, NO brackets, NO quotes ────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,*

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
API_TOKEN_EXPIRE_MINUTES=1440
BCRYPT_ROUNDS=12

# ── Scanner ───────────────────────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=3
SCAN_REQUEST_TIMEOUT=10
SCAN_CRAWL_DEPTH=5
SCAN_MAX_URLS=500
SCAN_RATE_LIMIT=120
SCANNER_USER_AGENT=VAPTForge/3.4.1 (Authorized Security Scanner)

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=./reports
MAX_REPORT_AGE_DAYS=90

# ── Frontend URL (for password reset links) ──────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email / SMTP (REQUIRED for real email sending) ────────────────────────────
#
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Create an App Password for "Mail"
#   4. Use that 16-char password below (NOT your Gmail login password)
#
# Sender email (fixed): vaptnotify@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vaptnotify@gmail.com
SMTP_PASS=oaeswkhfphvufwdh 
